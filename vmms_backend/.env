


JWT_SECRET=india123


# ============================================
# VMMS Backend - Environment Configuration
# ============================================

# ============================================
# Server Configuration
# ============================================
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug
USE_HTTPS=false
SSL_KEY_PATH=./assets/certs/server.key
SSL_CERT_PATH=./assets/certs/server.crt

USE_HTTPS=true
SSL_PFX_PATH=./assets/certs/server.pfx
SSL_PFX_PASSPHRASE=india123


# ============================================
# Database Configuration
# ============================================
# PostgreSQL Connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=svr_user
DB_PASSWORD=india123
DB_NAME=vmms_db
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# Redis Configuration (Optional - for caching)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# JWT Configuration
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=india123
JWT_EXPIRY=8h

# ============================================
# Encryption Configuration
# ============================================
# Generate 256-bit key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used for Aadhaar and sensitive document encryption
ENCRYPTION_KEY=your_256_bit_key_in_hex_format_32_characters_long_change_this_in_production
ENCRYPTION_ALGORITHM=aes-256-cbc

# ============================================
# SMS Configuration
# ============================================
SMS_PROVIDER=console
# Options: console, twilio, aws, custom

# Twilio Configuration (if SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# AWS SNS Configuration (if SMS_PROVIDER=aws)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ============================================
# File Upload Configuration
# ============================================
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
EXPORT_PATH=./exports

# Allowed document types
ALLOWED_DOC_TYPES=AADHAAR,PAN,POLICE_VERIFICATION,WORK_ORDER,ASO_RENEWAL,ASO_EXTENSION

# ============================================
# Biometric Configuration
# ============================================
# Store hashes (not raw biometric data) for GDPR compliance
STORE_BIOMETRIC_IMAGES=false
BIOMETRIC_ALGORITHM=SHA256

# ============================================
# Photo Management
# ============================================
# Live gate photos
STORE_LIVE_PHOTOS=true
LIVE_PHOTO_QUALITY=80
LIVE_PHOTO_MAX_WIDTH=640
LIVE_PHOTO_MAX_HEIGHT=480
LIVE_PHOTO_RETENTION_DAYS=90

# ============================================
# Cron Job Configuration
# ============================================
# Frequency of No-Show Detection (in minutes)
NOSHOW_CRON_INTERVAL=10
# No-show threshold (in minutes after manifest printing)
NOSHOW_THRESHOLD_MINUTES=60

# Frequency of Material Balance Check (in minutes)
MATERIAL_ALERT_CRON_INTERVAL=30

# Frequency of Master Whitelist Distribution (in minutes)
WHITELIST_SYNC_INTERVAL=5

# ============================================
# Gate Configuration
# ============================================
# Default gate online timeout (in minutes)
GATE_HEARTBEAT_TIMEOUT=5
# Maximum persons allowed inside simultaneously
MAX_CAPACITY_PER_AREA=500

# ============================================
# Offline Sync Configuration
# ============================================
# Offline sync queue retention (in days)
SYNC_QUEUE_RETENTION_DAYS=7
# Batch size for processing sync queue
SYNC_BATCH_SIZE=100

# ============================================
# API Configuration
# ============================================
API_PREFIX=/api
API_VERSION=v1
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Feature Flags
# ============================================
ENABLE_BIOMETRIC_AUTH=true
ENABLE_RFID_AUTH=true
ENABLE_MANUAL_OVERRIDE=true
ENABLE_SMS_ALERTS=true
ENABLE_OFFLINE_MODE=true
ENABLE_LIVE_PHOTO_CAPTURE=true

# ============================================
# Audit & Logging
# ============================================
AUDIT_LOG_RETENTION_DAYS=365
ENABLE_AUDIT_LOGGING=true
ENABLE_SECURITY_HEADERS=true

# ============================================
# GDPR & Privacy
# ============================================
# Hash biometric data (do not store raw images for GDPR compliance)
GDPR_COMPLIANT_MODE=true
# Auto-delete access logs older than X days
AUTO_DELETE_LOGS_DAYS=365

# ============================================
# Reporting
# ============================================
# PDF export configuration
PDF_FONT=Helvetica
PDF_MARGIN_TOP=20
PDF_MARGIN_BOTTOM=20
PDF_MARGIN_LEFT=15
PDF_MARGIN_RIGHT=15

# Excel export configuration
EXCEL_SHEET_PAGE_SETUP=A4

# ============================================
# Development/Testing
# ============================================
# Set to true to seed demo data on startup
SEED_DEMO_DATA=false
# Enable verbose request/response logging
DEBUG_API_CALLS=false
# Use mock SMS (for testing without consuming credits)
MOCK_SMS=false

GAMMU_CONFIG_WINDOWS=config/gammu.windows.ini
GAMMU_CONFIG_LINUX=config/gammu.linux.ini
